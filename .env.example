TELEGRAM_BOT_TOKEN=

# Supabase — Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Checkout (setup) + webhooks — public HTTPS base, no trailing slash (e.g. ngrok URL)
PUBLIC_BASE_URL=https://your-tunnel.example

# HTTP server for /webhooks/stripe/:merchantId and /stripe/setup-* pages
HTTP_PORT=8787

# Square API: sandbox (default) or production — must match your Square app credentials
SQUARE_ENVIRONMENT=sandbox
